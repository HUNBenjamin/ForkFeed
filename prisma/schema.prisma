generator client {
  provider      = "prisma-client-js"
  output        = "../app/prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Category {
  id          Int    @id @map("_id")
  created_at  String
  description String
  name        String

  @@map("categories")
}

model Comment {
  id         Int     @id @map("_id")
  content    String
  created_at String
  is_deleted Boolean
  recipe_id  Int
  updated_at String
  user_id    Int

  @@map("comments")
}

model Favorite {
  id         Int    @id @map("_id")
  created_at String
  recipe_id  Int
  user_id    Int

  @@map("favorites")
}

model Ingredient {
  id        Int    @id @map("_id")
  name      String
  quantity  Int
  recipe_id Int
  unit      String

  @@map("ingredients")
}

model Rating {
  id         Int    @id @map("_id")
  created_at String
  rating     Int
  recipe_id  Int
  user_id    Int

  @@map("ratings")
}

model RecipeBookRecipe {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  recipe_book_id Int
  recipe_id      Int

  @@map("recipe_book_recipes")
}

model RecipeBook {
  id          Int     @id @map("_id")
  created_at  String
  description String
  is_public   Boolean
  name        String
  owner_id    Int
  updated_at  String

  @@map("recipe_books")
}

model RecipeCategory {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  category_id Int
  recipe_id   Int

  @@map("recipe_categories")
}

model RecipeTag {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  recipe_id Int
  tag_id    Int

  @@map("recipe_tags")
}

model Recipe {
  id               Int     @id @map("_id")
  author_id        Int
  average_rating   Float
  created_at       String
  description      String
  difficulty       String
  is_deleted       Boolean
  preparation_time Int
  rating_count     Int
  title            String
  updated_at       String

  @@map("recipes")
}

model Report {
  id          Int    @id @map("_id")
  created_at  String
  reason      String
  reported_by Int
  /// Could not determine type: the field only had null or empty values in the sample set.
  reviewed_at Json?
  /// Could not determine type: the field only had null or empty values in the sample set.
  reviewed_by Json?
  status      String
  target_id   Int
  target_type String

  @@map("reports")
}

model Step {
  id          Int    @id @map("_id")
  description String
  recipe_id   Int
  step_number Int

  @@map("steps")
}

model Tag {
  id         Int    @id @map("_id")
  created_at String
  name       String

  @@map("tags")
}

model User {
  id                Int     @id @map("_id")
  bio               String
  created_at        String
  email             String
  is_active         Boolean
  last_login        String
  password_hash     String
  profile_image_url String
  role              String
  updated_at        String
  username          String

  @@map("users")
}
